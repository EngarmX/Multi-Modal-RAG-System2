        "# ============================================\n",
        "# PART C: Context Compression & Reranking\n",
        "# ============================================"
      ],
      "metadata": {
        "id": "CG2ZEIsJ4z2M"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"\\n📊 Building Context Compression Pipeline...\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "def compress_and_rerank(query: str, documents: list, top_k: int = 3) -> list:\n",
        "    \"\"\"\n",
        "    Compress and rerank retrieved documents for better relevance.\n",
        "\n",
        "    Args:\n",
        "        query: User's question\n",
        "        documents: Retrieved documents\n",
        "        top_k: Number of top documents to return\n",
        "\n",
        "    Returns:\n",
        "        List of most relevant documents\n",
        "    \"\"\"\n",
        "\n",
        "    # Create relevance scoring prompt\n",
        "    scoring_prompt = \"\"\"Rate the relevance of this document to the query on a scale of 0-10.\n",
        "\n",
        "Query: {query}\n",
        "\n",
        "Document: {document}\n",
        "\n",
        "Provide only a number between 0 and 10. No explanation needed.\n",
        "Your score:\"\"\"\n",
        "\n",
        "    scored_docs = []\n",
        "\n",
        "    for doc in documents:\n",
        "        try:\n",
        "            # Get relevance score\n",
        "            score_response = llm.invoke(\n",
        "                scoring_prompt.format(\n",
        "                    query=query,\n",
        "                    document=doc.page_content[:500]  # First 500 chars\n",
        "                )\n",
        "            )\n",
        "\n",
        "            # Extract score\n",
        "            score_text = score_response.content.strip()\n",
        "            score = float(score_text.split()[0])  # Get first number\n",
        "\n",
        "            scored_docs.append({\n",
        "                'document': doc,\n",
        "                'score': score\n",
        "            })\n",
        "\n",
        "        except:\n",
        "            # If scoring fails, assign neutral score\n",
        "            scored_docs.append({\n",
        "                'document': doc,\n",
        "                'score': 5.0\n",
        "            })\n",
        "\n",
        "    # Sort by score (highest first) and return top_k\n",
        "    scored_docs.sort(key=lambda x: x['score'], reverse=True)\n",
        "\n",
        "    return [item['document'] for item in scored_docs[:top_k]]\n",
        "\n",
        "print(\"✅ Compression & reranking function created!\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "BMV8XtAK4wQT",
        "outputId": "d47fa052-35ee-454f-88b9-24b9321870ea"
