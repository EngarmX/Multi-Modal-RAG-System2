      "source": [
        "# ============================================\n",
        "# PART C: Multi-Modal RAG Function\n",
        "# ============================================"
      ],
      "metadata": {
        "id": "hfyedmSBBP1D"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"\\n🔗 Building Multi-Modal RAG Pipeline...\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "def multimodal_rag(question: str, image_url: str = None, use_vision: bool = True):\n",
        "    \"\"\"\n",
        "    Multi-modal RAG: Combines text retrieval with vision analysis\n",
        "\n",
        "    Args:\n",
        "        question: User's question\n",
        "        image_url: Optional image URL\n",
        "        use_vision: Whether to use vision model\n",
        "\n",
        "    Returns:\n",
        "        dict with answer and metadata\n",
        "    \"\"\"\n",
        "\n",
        "    print(f\"\\n{'='*60}\")\n",
        "    print(f\"Question: {question}\")\n",
        "    if image_url:\n",
        "        print(f\"Image: {image_url}\")\n",
        "    print(f\"{'='*60}\")\n",
        "\n",
        "    result = {\n",
        "        'question': question,\n",
        "        'text_answer': None,\n",
        "        'vision_analysis': None,\n",
        "        'combined_answer': None,\n",
        "        'sources': []\n",
        "    }\n",
        "\n",
        "    # Step 1: Text-based RAG\n",
        "    print(\"\\n[1/3] 📚 Retrieving text information...\")\n",
        "    retrieved_docs = retriever.invoke(question)\n",
        "\n",
        "    if retrieved_docs:\n",
        "        context = \"\\n\\n\".join([\n",
        "            f\"[{doc.metadata.get('company')}]\\n{doc.page_content[:300]}\"\n",
        "            for doc in retrieved_docs[:2]\n",
        "        ])\n",
        "\n",
        "        text_prompt = f\"\"\"Answer based on context:\n",
        "\n",
        "{context}\n",
        "\n",
        "Question: {question}\n",
        "\n",
        "Answer:\"\"\"\n",
        "\n",
        "        text_response = llm.invoke(text_prompt)\n",
        "        result['text_answer'] = text_response.content\n",
        "        result['sources'] = [doc.metadata.get('company') for doc in retrieved_docs[:2]]\n",
        "\n",
        "        print(f\"   ✅ Retrieved from: {', '.join(result['sources'])}\")\n",
        "\n",
        "    # Step 2: Vision Analysis (if image provided)\n",
        "    if image_url and use_vision:\n",
        "        print(\"\\n[2/3] 👁️ Analyzing image...\")\n",
        "\n",
        "        image = load_image_from_url(image_url)\n",
        "\n",
        "        if image:\n",
        "            # Generate caption\n",
        "            caption = generate_caption(image)\n",
        "            result['vision_analysis'] = {\n",
        "                'caption': caption,\n",
        "                'image_url': image_url\n",
        "            }\n",
        "\n",
        "            print(f\"   ✅ Image caption: {caption}\")\n",
        "\n",
        "            # Display image\n",
        "            plt.figure(figsize=(8, 6))\n",
        "            plt.imshow(image)\n",
        "            plt.axis('off')\n",
        "            plt.title(f\"Caption: {caption}\", fontsize=12, wrap=True)\n",
        "            plt.tight_layout()\n",
        "            plt.show()\n",
        "\n",
        "    # Step 3: Combine text and vision (if both available)\n",
        "    print(\"\\n[3/3] 🧠 Generating final answer...\")\n",
        "\n",
        "    if result['text_answer'] and result['vision_analysis']:\n",
        "        # Combine both sources\n",
        "        combined_prompt = f\"\"\"Provide a comprehensive answer using both text information and visual analysis.\n",
        "\n",
        "Text Information:\n",
        "{result['text_answer']}\n",
        "\n",
        "Visual Analysis:\n",
        "Image shows: {result['vision_analysis']['caption']}\n",
        "\n",
        "Question: {question}\n",
        "\n",
        "Provide a unified answer that combines both sources:\"\"\"\n",
        "\n",
        "        combined_response = llm.invoke(combined_prompt)\n",
        "        result['combined_answer'] = combined_response.content\n",
        "\n",
        "        print(\"   ✅ Combined text + vision analysis\")\n",
        "\n",
        "    elif result['text_answer']:\n",
        "        result['combined_answer'] = result['text_answer']\n",
        "        print(\"   ✅ Text-only answer\")\n",
        "\n",
        "    elif result['vision_analysis']:\n",
        "        result['combined_answer'] = f\"Based on the image: {result['vision_analysis']['caption']}\"\n",
        "        print(\"   ✅ Vision-only answer\")\n",
        "\n",
        "    return result\n",
        "\n",
        "print(\"✅ Multi-modal RAG pipeline ready!\")"
      ],
      "metadata": {
