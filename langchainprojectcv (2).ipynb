      "source": [
        "print(\"\\n⚡ Creating Complete RAG Pipeline...\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "def advanced_rag_query(question: str, use_reranking: bool = True, verbose: bool = True):\n",
        "    \"\"\"\n",
        "    Complete RAG pipeline with optional reranking.\n",
        "\n",
        "    Args:\n",
        "        question: User's question\n",
        "        use_reranking: Whether to use document reranking\n",
        "        verbose: Whether to print intermediate steps\n",
        "\n",
        "    Returns:\n",
        "        dict with answer and metadata\n",
        "    \"\"\"\n",
        "\n",
        "    if verbose:\n",
        "        print(f\"\\n{'='*60}\")\n",
        "        print(f\"Question: {question}\")\n",
        "        print(f\"{'='*60}\")\n",
        "\n",
        "    # Step 1: Retrieve documents\n",
        "    if verbose:\n",
        "        print(\"\\n[1/3] 🔍 Retrieving documents...\")\n",
        "\n",
        "    retrieved_docs = retriever.invoke(question)\n",
        "\n",
        "    if verbose:\n",
        "        print(f\"      Retrieved: {len(retrieved_docs)} documents\")\n",
        "\n",
        "    # Step 2: Optional reranking\n",
        "    if use_reranking and len(retrieved_docs) > 0:\n",
        "        if verbose:\n",
        "            print(\"\\n[2/3] 📊 Reranking documents...\")\n",
        "\n",
        "        final_docs = compress_and_rerank(question, retrieved_docs, top_k=3)\n",
        "\n",
        "        if verbose:\n",
        "            print(f\"      Reranked to top: {len(final_docs)} documents\")\n",
        "    else:\n",
        "        final_docs = retrieved_docs[:3]\n",
        "\n",
        "    # Step 3: Generate answer\n",
        "    if verbose:\n",
        "        print(\"\\n[3/3] 🤖 Generating answer...\")\n",
        "\n",
        "    answer = rag_chain.invoke({\n",
        "        \"documents\": final_docs,\n",
        "        \"question\": question\n",
        "    })\n",
        "\n",
        "    if verbose:\n",
        "        print(\"      ✅ Answer generated!\")\n",
        "\n",
        "    # Return structured result\n",
        "    return {\n",
        "        'question': question,\n",
        "        'answer': answer,\n",
        "        'num_sources': len(final_docs),\n",
        "        'sources': [\n",
        "            {\n",
        "                'company': doc.metadata.get('company'),\n",
        "                'url': doc.metadata.get('url'),\n",
        "                'snippet': doc.page_content[:150] + \"...\"\n",
        "            }\n",
        "            for doc in final_docs\n",
        "        ]\n",
        "    }\n",
        "\n",
        "print(\"✅ Complete RAG pipeline ready!\")"
