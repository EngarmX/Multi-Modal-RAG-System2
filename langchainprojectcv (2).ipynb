    {
      "cell_type": "code",
      "source": [
        "# Function to clean text data\n",
        "def clean_text(text: str) -> str:\n",
        "    \"\"\"\n",
        "    Clean text by removing:\n",
        "    - Special characters\n",
        "    - Extra whitespace\n",
        "    - URLs\n",
        "    - References like [1], [2]\n",
        "    \"\"\"\n",
        "    # Remove URLs\n",
        "    text = re.sub(r'http\\S+|www.\\S+', '', text)\n",
        "\n",
        "    # Remove reference numbers like [1], [2], etc.\n",
        "    text = re.sub(r'\\[\\d+\\]', '', text)\n",
        "\n",
        "    # Remove extra whitespace\n",
        "    text = re.sub(r'\\s+', ' ', text)\n",
        "\n",
        "    # Remove special characters but keep basic punctuation\n",
        "    text = re.sub(r'[^\\w\\s.,!?-]', '', text)\n",
        "\n",
        "    # Strip leading/trailing whitespace\n",
        "    text = text.strip()\n",
        "\n",
        "    return text"
      ],
      "metadata": {
        "id": "nVWCSAZo8A50"
      },
      "execution_count": 45,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import wikipedia\n",
        "import pandas as pd\n",
        "import time\n",
        "\n",
        "# 1. Fix the API block\n",
        "wikipedia.set_user_agent(\"MyCompanyDataBot/1.0 (mohamedsafwat648@gmail.com)\")\n",
        "\n",
        "documents = []\n",
        "failed = []\n",
        "\n",
        "print(\"\\n⏳ Fetching articles...\\n\")\n",
        "\n",
        "for i, company in enumerate(companies, 1):\n",
        "    try:\n",
        "        print(f\"[{i}/{len(companies)}] Fetching: {company}...\", end=\" \")\n",
        "\n",
        "        # 2. Get Wikipedia page (auto_suggest=False is great for exact matches)\n",
        "        page = wikipedia.page(company, auto_suggest=False)\n",
        "\n",
        "        # 3. Wrap extraction in secondary try-except to catch weird formatting crashes\n",
        "        try:\n",
        "            raw_content = page.content\n",
        "            summary = page.summary\n",
        "        except Exception as extract_error:\n",
        "            print(f\"❌ Extraction failed\")\n",
        "            failed.append(company)\n",
        "            continue\n",
        "\n",
        "        # Clean the content (assuming clean_text is defined elsewhere)\n",
        "        cleaned_content = clean_text(raw_content)\n",
        "        cleaned_summary = clean_text(summary)\n",
        "\n",
        "        # Store document with metadata\n",
        "        doc = {\n",
        "            'company': company,\n",
        "            'title': page.title,\n",
        "            'url': page.url,\n",
        "            'summary': cleaned_summary,\n",
        "            'full_content': cleaned_content,\n",
        "            'content_length': len(cleaned_content),\n",
        "            'word_count': len(cleaned_content.split()),\n",
        "            'collected_at': pd.Timestamp.now().strftime('%Y-%m-%d %H:%M:%S')\n",
        "        }\n",
        "\n",
        "        documents.append(doc)\n",
        "        print(f\"✅ ({len(cleaned_content)} chars)\")\n",
        "\n",
        "        # 4. Be polite! Bump this to 1 second if you still see occasional blocks\n",
        "        time.sleep(1.0)\n",
        "\n",
        "    except wikipedia.exceptions.DisambiguationError:\n",
        "        print(f\"❌ Disambiguation error\")\n",
        "        failed.append(company)\n",
        "    except wikipedia.exceptions.PageError:\n",
        "        print(f\"❌ Page not found\")\n",
        "        failed.append(company)\n",
        "    except Exception as e:\n",
        "        print(f\"❌ Error: {str(e)[:50]}\")\n",
        "        failed.append(company)\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(f\"✅ Successfully collected: {len(documents)} articles\")\n",
        "if failed:\n",
        "    print(f\"⚠️  Failed to collect: {len(failed)} articles\")\n",
        "    print(f\"   Failed: {', '.join(failed)}\")"
      ],
