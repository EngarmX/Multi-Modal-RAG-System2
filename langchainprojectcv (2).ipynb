        "# ============================================\n",
        "# PART A: Interactive Demo System\n",
        "# ============================================"
      ],
      "metadata": {
        "id": "68NdtBtaCqpp"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"\\n🎮 Building Interactive Demo System...\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "class RAGDemoSystem:\n",
        "    \"\"\"Complete RAG demo system with metrics tracking\"\"\"\n",
        "\n",
        "    def __init__(self, retriever, llm, vectorstore):\n",
        "        self.retriever = retriever\n",
        "        self.llm = llm\n",
        "        self.vectorstore = vectorstore\n",
        "        self.query_history = []\n",
        "        self.performance_metrics = []\n",
        "\n",
        "    def query(self, question: str, show_sources: bool = True):\n",
        "        \"\"\"Execute a query and track metrics\"\"\"\n",
        "\n",
        "        start_time = time.time()\n",
        "\n",
        "        print(f\"\\n{'='*60}\")\n",
        "        print(f\"❓ QUESTION: {question}\")\n",
        "        print(f\"{'='*60}\")\n",
        "\n",
        "        # Retrieve documents\n",
        "        print(\"\\n[1/3] 🔍 Retrieving relevant documents...\")\n",
        "        retrieved_docs = self.retriever.invoke(question)\n",
        "        retrieval_time = time.time() - start_time\n",
        "\n",
        "        print(f\"      ✅ Found {len(retrieved_docs)} documents ({retrieval_time:.2f}s)\")\n",
        "\n",
        "        # Generate answer\n",
        "        print(\"\\n[2/3] 🤖 Generating answer...\")\n",
        "        gen_start = time.time()\n",
        "\n",
        "        context = \"\\n\\n\".join([\n",
        "            f\"[Source: {doc.metadata.get('company')}]\\n{doc.page_content}\"\n",
        "            for doc in retrieved_docs[:3]\n",
        "        ])\n",
        "\n",
        "        prompt = f\"\"\"Answer the question based on the context below. Be specific and cite sources.\n",
        "\n",
        "Context:\n",
        "{context}\n",
        "\n",
        "Question: {question}\n",
        "\n",
        "Answer:\"\"\"\n",
        "\n",
        "        response = self.llm.invoke(prompt)\n",
        "        answer = response.content\n",
        "        generation_time = time.time() - gen_start\n",
        "\n",
        "        total_time = time.time() - start_time\n",
        "\n",
        "        print(f\"      ✅ Answer generated ({generation_time:.2f}s)\")\n",
        "\n",
        "        # Display answer\n",
        "        print(\"\\n[3/3] 📝 ANSWER:\")\n",
        "        print(\"-\" * 60)\n",
        "        print(answer)\n",
        "        print(\"-\" * 60)\n",
        "\n",
        "        # Show sources if requested\n",
        "        if show_sources and retrieved_docs:\n",
        "            print(\"\\n📚 SOURCES:\")\n",
        "            for i, doc in enumerate(retrieved_docs[:3], 1):\n",
        "                company = doc.metadata.get('company', 'Unknown')\n",
        "                url = doc.metadata.get('url', 'N/A')\n",
        "                print(f\"   [{i}] {company}\")\n",
        "                print(f\"       URL: {url}\")\n",
        "                print(f\"       Snippet: {doc.page_content[:100]}...\")\n",
        "\n",
        "        # Store metrics\n",
        "        metrics = {\n",
        "            'question': question,\n",
        "            'num_docs_retrieved': len(retrieved_docs),\n",
        "            'retrieval_time': retrieval_time,\n",
        "            'generation_time': generation_time,\n",
        "            'total_time': total_time,\n",
        "            'answer_length': len(answer),\n",
        "            'sources_used': [doc.metadata.get('company') for doc in retrieved_docs[:3]]\n",
        "        }\n",
        "\n",
        "        self.query_history.append({\n",
        "            'question': question,\n",
        "            'answer': answer,\n",
        "            'sources': metrics['sources_used']\n",
        "        })\n",
        "\n",
        "        self.performance_metrics.append(metrics)\n",
        "\n",
        "        print(f\"\\n⏱️  Performance: {total_time:.2f}s total (retrieval: {retrieval_time:.2f}s, generation: {generation_time:.2f}s)\")\n",
        "\n",
        "        return {\n",
        "            'answer': answer,\n",
        "            'sources': retrieved_docs[:3],\n",
        "            'metrics': metrics\n",
        "        }\n",
        "\n",
        "    def show_statistics(self):\n",
        "        \"\"\"Display comprehensive statistics\"\"\"\n",
        "\n",
        "        if not self.performance_metrics:\n",
        "            print(\"⚠️  No queries executed yet!\")\n",
        "            return\n",
        "\n",
        "        print(\"\\n\" + \"=\"*60)\n",
        "        print(\"📊 SYSTEM STATISTICS\")\n",
        "        print(\"=\"*60)\n",
        "\n",
        "        df = pd.DataFrame(self.performance_metrics)\n",
        "\n",
        "        # Overall metrics\n",
        "        print(f\"\\n📈 Overall Performance:\")\n",
        "        print(f\"   Total queries: {len(df)}\")\n",
        "        print(f\"   Avg retrieval time: {df['retrieval_time'].mean():.3f}s\")\n",
        "        print(f\"   Avg generation time: {df['generation_time'].mean():.3f}s\")\n",
        "        print(f\"   Avg total time: {df['total_time'].mean():.3f}s\")\n",
        "        print(f\"   Avg documents retrieved: {df['num_docs_retrieved'].mean():.1f}\")\n",
        "        print(f\"   Avg answer length: {df['answer_length'].mean():.0f} chars\")\n",
        "\n",
        "        # Source distribution\n",
        "        all_sources = [source for sources in df['sources_used'] for source in sources]\n",
        "        source_counts = Counter(all_sources)\n",
        "\n",
        "        print(f\"\\n📚 Source Distribution:\")\n",
        "        for source, count in source_counts.most_common(5):\n",
        "            print(f\"   {source}: {count} times\")\n",
        "\n",
        "        return df\n",
        "\n",
        "# Initialize demo system\n",
        "demo = RAGDemoSystem(retriever, llm, vectorstore)\n",
        "\n",
        "print(\"✅ Interactive demo system ready!\")\n"
      ],
