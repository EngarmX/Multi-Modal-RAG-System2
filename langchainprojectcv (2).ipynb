        "# ============================================\n",
        "# PART C: Generate Embeddings\n",
        "# ============================================"
      ],
      "metadata": {
        "id": "PvW-anH1CfFp"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"\\n🔮 Generating embeddings...\")\n",
        "print(\"=\" * 60)\n",
        "print(\"⏳ This takes ~2-3 minutes for all chunks...\\n\")\n",
        "\n",
        "# Extract text from chunks\n",
        "texts = [chunk['text'] for chunk in chunked_documents]\n",
        "\n",
        "# Generate embeddings in batches (more efficient)\n",
        "batch_size = 32\n",
        "embeddings_list = []\n",
        "\n",
        "for i in range(0, len(texts), batch_size):\n",
        "    batch_texts = texts[i:i+batch_size]\n",
        "    batch_embeddings = embedding_model.encode(batch_texts, show_progress_bar=False)\n",
        "    embeddings_list.append(batch_embeddings)\n",
        "\n",
        "    # Show progress\n",
        "    if (i // batch_size + 1) % 10 == 0:\n",
        "        print(f\"  Processed {i + len(batch_texts)}/{len(texts)} chunks...\")\n",
        "\n",
        "# Combine all embeddings\n",
        "embeddings = np.vstack(embeddings_list)\n",
        "\n",
        "print(f\"\\n✅ Generated embeddings!\")\n",
        "print(f\"   Shape: {embeddings.shape}\")\n",
        "print(f\"   (Total chunks: {embeddings.shape[0]}, Dimensions: {embeddings.shape[1]})\")\n",
        "\n",
        "# Add embeddings to chunked documents\n",
        "for i, chunk in enumerate(chunked_documents):\n",
        "    chunk['embedding'] = embeddings[i]"
      ],
