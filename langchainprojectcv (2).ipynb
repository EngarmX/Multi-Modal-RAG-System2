      "cell_type": "code",
      "source": [
        "print(\"\\n📊 Visualizing embedding space...\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# Use PCA to reduce to 2D for visualization\n",
        "print(\"⏳ Reducing dimensions with PCA...\")\n",
        "pca = PCA(n_components=2)\n",
        "embeddings_2d = pca.fit_transform(embeddings)\n",
        "\n",
        "# Create company labels for coloring\n",
        "company_labels = [chunk['company'] for chunk in chunked_documents]\n",
        "\n",
        "# Create interactive plot\n",
        "print(\"⏳ Creating visualization...\")\n",
        "\n",
        "fig = go.Figure()\n",
        "\n",
        "# Get unique companies and assign colors\n",
        "unique_companies = list(set(company_labels))\n",
        "colors = px.colors.qualitative.Plotly[:len(unique_companies)]\n",
        "\n",
        "for i, company in enumerate(unique_companies):\n",
        "    # Get indices for this company\n",
        "    indices = [j for j, label in enumerate(company_labels) if label == company]\n",
        "\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=embeddings_2d[indices, 0],\n",
        "        y=embeddings_2d[indices, 1],\n",
        "        mode='markers',\n",
        "        name=company,\n",
        "        marker=dict(size=8, opacity=0.7),\n",
        "        text=[chunked_documents[j]['text'][:100] + \"...\" for j in indices],\n",
        "        hovertemplate='<b>%{fullData.name}</b><br>%{text}<extra></extra>'\n",
        "    ))\n",
        "\n",
        "fig.update_layout(\n",
        "    title=\"Document Embeddings in 2D Space (PCA)\",\n",
        "    xaxis_title=\"Principal Component 1\",\n",
        "    yaxis_title=\"Principal Component 2\",\n",
        "    width=900,\n",
        "    height=600,\n",
        "    hovermode='closest'\n",
        ")\n",
        "\n",
        "fig.show()\n",
        "\n",
        "print(\"\\n✅ Visualization complete!\")\n",
        "print(\"   💡 Hover over points to see text snippets\")\n",
        "print(\"   💡 Similar documents cluster together\")"
