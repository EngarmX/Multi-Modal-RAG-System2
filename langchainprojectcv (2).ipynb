        "def chat_node(state: ConversationState) -> ConversationState:\n",
        "    question = state[\"question\"]\n",
        "    print(f\"   💬 Chat mode...\")\n",
        "\n",
        "    response = llm.invoke(f\"Be a helpful assistant. User: {question}\")\n",
        "    state[\"answer\"] = response.content\n",
        "\n",
        "    state[\"messages\"].extend([HumanMessage(content=question), AIMessage(content=state[\"answer\"])])\n",
        "    print(f\"   ✅ Chat complete\")\n",
        "    return state\n",
        "\n",
        "print(\"✅ Chat node created!\")"
      ],
      "metadata": {
