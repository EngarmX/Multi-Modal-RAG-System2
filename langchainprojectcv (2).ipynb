        "# ============================================\n",
        "# PART B: Chunk Documents for Better Retrieval\n",
        "# ============================================"
      ],
      "metadata": {
        "id": "Iyy-o3vZCMBl"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"\\n✂️  Chunking documents for optimal retrieval...\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "from langchain_text_splitters import RecursiveCharacterTextSplitter\n",
        "\n",
        "# Create text splitter\n",
        "text_splitter = RecursiveCharacterTextSplitter(\n",
        "    chunk_size=1000,  # Each chunk ~1000 characters\n",
        "    chunk_overlap=200,  # 200 char overlap to maintain context\n",
        "    length_function=len,\n",
        "    separators=[\"\\n\\n\", \"\\n\", \". \", \" \", \"\"]\n",
        ")\n",
        "\n",
        "# Chunk all documents\n",
        "chunked_documents = []\n",
        "chunk_id = 0\n",
        "\n",
        "print(\"⏳ Splitting documents into chunks...\\n\")\n",
        "\n",
        "for doc in cleaned_documents:\n",
        "    # Split the content\n",
        "    chunks = text_splitter.split_text(doc['full_content'])\n",
        "\n",
        "    print(f\"  {doc['company']}: {len(chunks)} chunks\")\n",
        "\n",
        "    # Create metadata for each chunk\n",
        "    for i, chunk in enumerate(chunks):\n",
        "        chunked_doc = {\n",
        "            'chunk_id': chunk_id,\n",
        "            'company': doc['company'],\n",
        "            'title': doc['title'],\n",
        "            'url': doc['url'],\n",
        "            'chunk_index': i,\n",
        "            'total_chunks': len(chunks),\n",
        "            'text': chunk,\n",
        "            'char_count': len(chunk),\n",
        "            'word_count': len(chunk.split())\n",
        "        }\n",
        "        chunked_documents.append(chunked_doc)\n",
        "        chunk_id += 1\n",
        "\n",
        "print(f\"\\n✅ Created {len(chunked_documents)} chunks from {len(cleaned_documents)} documents\")\n",
        "print(f\"   Average chunk size: {np.mean([c['char_count'] for c in chunked_documents]):.0f} characters\")"
      ],
