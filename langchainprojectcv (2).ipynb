        "\n",
        "def rag_node(state: ConversationState) -> ConversationState:\n",
        "    question = state[\"question\"]\n",
        "    print(f\"   📚 Executing RAG...\")\n",
        "\n",
        "    retrieved_docs = retriever.invoke(question)\n",
        "    state[\"documents\"] = retrieved_docs[:3]\n",
        "\n",
        "    context = \"\\n\\n\".join([f\"[{doc.metadata.get('company')}]\\n{doc.page_content}\"\n",
        "                           for doc in state[\"documents\"]])\n",
        "\n",
        "    prompt = f\"Answer based on context:\\n{context}\\n\\nQuestion: {question}\\nAnswer:\"\n",
        "    response = llm.invoke(prompt)\n",
        "    state[\"answer\"] = response.content\n",
        "\n",
        "    state[\"messages\"].extend([HumanMessage(content=question), AIMessage(content=state[\"answer\"])])\n",
        "    print(f\"   ✅ RAG complete\")\n",
        "    return state\n",
        "\n",
